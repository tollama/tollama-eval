<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ts-autopilot Report</title>
    <style>
        body { font-family: sans-serif; max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
        table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
        th, td { border: 1px solid #ccc; padding: 0.5rem 1rem; text-align: left; }
        th { background: #f0f0f0; }
        tr:nth-child(even) { background: #f9f9f9; }
        .rank-1 { font-weight: bold; color: #155724; }
    </style>
</head>
<body>
    <h1>ts-autopilot Benchmark Report</h1>

    <h2>Dataset Summary</h2>
    <table>
        <tr><th>Metric</th><th>Value</th></tr>
        <tr><td>Number of Series</td><td>{{ profile.n_series }}</td></tr>
        <tr><td>Frequency</td><td>{{ profile.frequency }}</td></tr>
        <tr><td>Season Length Guess</td><td>{{ profile.season_length_guess }}</td></tr>
        <tr><td>Missing Ratio</td><td>{{ "%.4f"|format(profile.missing_ratio) }}</td></tr>
        <tr><td>Min Series Length</td><td>{{ profile.min_length }}</td></tr>
        <tr><td>Max Series Length</td><td>{{ profile.max_length }}</td></tr>
        <tr><td>Total Rows</td><td>{{ profile.total_rows }}</td></tr>
        <tr><td>Forecast Horizon</td><td>{{ config.horizon }}</td></tr>
        <tr><td>CV Folds</td><td>{{ config.n_folds }}</td></tr>
    </table>

    <h2>Leaderboard</h2>
    <table>
        <tr>
            <th>Rank</th>
            <th>Model</th>
            <th>Mean MASE</th>
        </tr>
        {% for entry in leaderboard %}
        <tr class="{% if entry.rank == 1 %}rank-1{% endif %}">
            <td>{{ entry.rank }}</td>
            <td>{{ entry.name }}</td>
            <td>{{ "%.6f"|format(entry.mean_mase) }}</td>
        </tr>
        {% endfor %}
    </table>

    <h2>Model Details</h2>
    {% for model in models %}
    <h3>{{ model.name }}</h3>
    <p>Runtime: {{ "%.4f"|format(model.runtime_sec) }}s |
       Mean MASE: {{ "%.6f"|format(model.mean_mase) }} |
       Std MASE: {{ "%.6f"|format(model.std_mase) }}</p>
    <table>
        <tr><th>Fold</th><th>Cutoff</th><th>MASE</th></tr>
        {% for fold in model.folds %}
        <tr>
            <td>{{ fold.fold }}</td>
            <td>{{ fold.cutoff }}</td>
            <td>{{ "%.6f"|format(fold.mase) }}</td>
        </tr>
        {% endfor %}
    </table>
    {% endfor %}

    <footer>
        <p><small>Generated by ts-autopilot v0.1.0</small></p>
    </footer>
</body>
</html>
