<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ts-autopilot Report</title>
    <script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
    <style>
        :root {
            --green: #28a745;
            --green-bg: #d4edda;
            --red: #dc3545;
            --red-bg: #f8d7da;
            --yellow: #856404;
            --yellow-bg: #fff3cd;
            --yellow-border: #ffc107;
            --gold: #ffc107;
            --silver: #adb5bd;
            --bronze: #cd7f32;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            max-width: 1060px; margin: 2rem auto; padding: 0 1.5rem;
            color: #212529; line-height: 1.5;
        }
        h1 { border-bottom: 2px solid #dee2e6; padding-bottom: 0.5rem; }
        h2 { margin-top: 2rem; color: #495057; }
        h3 { color: #495057; }
        table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
        th, td { border: 1px solid #dee2e6; padding: 0.5rem 1rem; text-align: left; }
        th { background: #f8f9fa; font-weight: 600; }
        tr:nth-child(even) { background: #f8f9fa; }

        .rank-1 { font-weight: bold; }
        .rank-1 td:first-child { color: var(--gold); }
        .rank-2 td:first-child { color: var(--silver); }
        .rank-3 td:first-child { color: var(--bronze); }

        .mase-good { color: var(--green); font-weight: 600; }
        .mase-bad { color: var(--red); font-weight: 600; }

        .warnings-box {
            background: var(--yellow-bg); border: 1px solid var(--yellow-border);
            border-radius: 6px; padding: 0.75rem 1rem; margin: 1rem 0;
            color: var(--yellow);
        }
        .warnings-box ul { margin: 0.25rem 0 0 0; padding-left: 1.25rem; }

        .worst-series { background: var(--red-bg); }
        .meta { color: #6c757d; font-size: 0.9rem; }

        .chart-container { margin: 1.5rem 0; }

        @media print {
            body { max-width: 100%; margin: 0; }
            tr:nth-child(even) { background: transparent !important; }
            th { background: transparent !important; border-bottom: 2px solid #000; }
        }
    </style>
</head>
<body>
    <h1>ts-autopilot Benchmark Report</h1>

    {% if warnings %}
    <div class="warnings-box">
        <strong>Warnings:</strong>
        <ul>
        {% for w in warnings %}
            <li>{{ w }}</li>
        {% endfor %}
        </ul>
    </div>
    {% endif %}

    <h2>Dataset Summary</h2>
    <table>
        <tr><th>Metric</th><th>Value</th></tr>
        <tr><td>Number of Series</td><td>{{ profile.n_series }}</td></tr>
        <tr><td>Frequency</td><td>{{ profile.frequency }}</td></tr>
        <tr><td>Season Length Guess</td><td>{{ profile.season_length_guess }}</td></tr>
        <tr><td>Missing Ratio</td><td>{{ "%.4f"|format(profile.missing_ratio) }}</td></tr>
        <tr><td>Min Series Length</td><td>{{ profile.min_length }}</td></tr>
        <tr><td>Max Series Length</td><td>{{ profile.max_length }}</td></tr>
        <tr><td>Total Rows</td><td>{{ profile.total_rows }}</td></tr>
        <tr><td>Forecast Horizon</td><td>{{ config.horizon }}</td></tr>
        <tr><td>CV Folds</td><td>{{ config.n_folds }}</td></tr>
    </table>

    <h2>Leaderboard</h2>

    <div id="chart-mase" class="chart-container"></div>

    <table>
        <tr>
            <th>Rank</th>
            <th>Model</th>
            <th>MASE</th>
            <th>SMAPE</th>
            <th>RMSSE</th>
            <th>MAE</th>
        </tr>
        {% for entry in leaderboard %}
        <tr class="{% if entry.rank == 1 %}rank-1{% elif entry.rank == 2 %}rank-2{% elif entry.rank == 3 %}rank-3{% endif %}">
            <td>{{ entry.rank }}</td>
            <td>{{ entry.name }}</td>
            <td class="{% if entry.mean_mase < 1.0 %}mase-good{% elif entry.mean_mase > 1.0 %}mase-bad{% endif %}">{{ "%.4f"|format(entry.mean_mase) }}</td>
            <td>{{ "%.2f"|format(entry.mean_smape) }}%</td>
            <td class="{% if entry.mean_rmsse < 1.0 %}mase-good{% elif entry.mean_rmsse > 1.0 %}mase-bad{% endif %}">{{ "%.4f"|format(entry.mean_rmsse) }}</td>
            <td>{{ "%.4f"|format(entry.mean_mae) }}</td>
        </tr>
        {% endfor %}
    </table>

    <h2>MASE by Fold</h2>
    <div id="chart-heatmap" class="chart-container"></div>

    <h2>Model Details</h2>
    {% for model in models %}
    <h3>{{ model.name }}</h3>
    <p>Runtime: {{ "%.4f"|format(model.runtime_sec) }}s |
       Mean MASE: <span class="{% if model.mean_mase < 1.0 %}mase-good{% elif model.mean_mase > 1.0 %}mase-bad{% endif %}">{{ "%.4f"|format(model.mean_mase) }}</span> |
       Std MASE: {{ "%.4f"|format(model.std_mase) }} |
       SMAPE: {{ "%.2f"|format(model.mean_smape) }}% |
       RMSSE: {{ "%.4f"|format(model.mean_rmsse) }} |
       MAE: {{ "%.4f"|format(model.mean_mae) }}</p>
    <table>
        <tr><th>Fold</th><th>Cutoff</th><th>MASE</th><th>SMAPE</th><th>RMSSE</th><th>MAE</th></tr>
        {% for fold in model.folds %}
        <tr>
            <td>{{ fold.fold }}</td>
            <td>{{ fold.cutoff }}</td>
            <td class="{% if fold.mase < 1.0 %}mase-good{% elif fold.mase > 1.0 %}mase-bad{% endif %}">{{ "%.4f"|format(fold.mase) }}</td>
            <td>{{ "%.2f"|format(fold.smape) }}%</td>
            <td class="{% if fold.rmsse < 1.0 %}mase-good{% elif fold.rmsse > 1.0 %}mase-bad{% endif %}">{{ "%.4f"|format(fold.rmsse) }}</td>
            <td>{{ "%.4f"|format(fold.mae) }}</td>
        </tr>
        {% endfor %}
    </table>

    {% if model.folds and model.folds[0].series_scores %}
    <details>
        <summary style="cursor: pointer; font-weight: 500; margin: 0.5rem 0;">Per-Series Breakdown (averaged across folds)</summary>
        {% set ns = namespace(avg_scores={}) %}
        {% for fold in model.folds %}
            {% for sid, score in fold.series_scores.items() %}
                {% if sid in ns.avg_scores %}
                    {% set _ = ns.avg_scores.update({sid: ns.avg_scores[sid] + score / model.folds|length}) %}
                {% else %}
                    {% set _ = ns.avg_scores.update({sid: score / model.folds|length}) %}
                {% endif %}
            {% endfor %}
        {% endfor %}
        <table>
            <tr><th>Series</th><th>Avg MASE</th></tr>
            {% for sid, score in ns.avg_scores|dictsort(by='value', reverse=true) %}
            <tr>
                <td>{{ sid }}</td>
                <td class="{% if score < 1.0 %}mase-good{% elif score > 1.0 %}mase-bad{% endif %}{% if loop.index <= 3 %} worst-series{% endif %}">{{ "%.6f"|format(score) }}</td>
            </tr>
            {% endfor %}
        </table>
    </details>
    {% endif %}
    {% endfor %}

    {% if tollama_interpretation %}
    <h2>LLM Interpretation</h2>
    <div style="background: #f0f7ff; border: 1px solid #b3d7ff; border-radius: 6px; padding: 1rem 1.25rem; margin: 1rem 0; white-space: pre-wrap;">{{ tollama_interpretation }}</div>
    {% endif %}

    <footer>
        <p class="meta">Generated by ts-autopilot v{{ version }} | {{ generated_at }}</p>
    </footer>

    <script>
    (function() {
        var chartData = {{ chart_data | tojson }};

        // MASE Comparison Bar Chart
        if (chartData.bar_names.length > 0) {
            var barTrace = {
                type: 'bar',
                orientation: 'h',
                y: chartData.bar_names.slice().reverse(),
                x: chartData.bar_mase.slice().reverse(),
                marker: { color: chartData.bar_colors.slice().reverse() },
                text: chartData.bar_mase.slice().reverse().map(function(v) { return v.toFixed(4); }),
                textposition: 'outside',
                hovertemplate: '%{y}: MASE=%{x:.4f}<extra></extra>'
            };
            Plotly.newPlot('chart-mase', [barTrace], {
                title: { text: 'Model Comparison (MASE)', font: { size: 16 } },
                xaxis: { title: 'MASE (lower is better)', zeroline: true },
                yaxis: { automargin: true },
                shapes: [{
                    type: 'line', x0: 1, x1: 1, y0: -0.5, y1: chartData.bar_names.length - 0.5,
                    line: { color: '#6c757d', width: 2, dash: 'dash' }
                }],
                annotations: [{
                    x: 1, y: chartData.bar_names.length - 0.5,
                    text: 'Naive baseline', showarrow: false,
                    font: { size: 11, color: '#6c757d' }, xanchor: 'left', xshift: 4
                }],
                margin: { l: 120, r: 60, t: 50, b: 40 },
                height: Math.max(250, chartData.bar_names.length * 45 + 100)
            }, { responsive: true });
        }

        // MASE by Fold Heatmap
        if (chartData.heatmap_z.length > 0) {
            var heatTrace = {
                type: 'heatmap',
                z: chartData.heatmap_z,
                x: chartData.heatmap_folds,
                y: chartData.heatmap_models,
                colorscale: [
                    [0, '#28a745'],
                    [0.5, '#ffc107'],
                    [1, '#dc3545']
                ],
                colorbar: { title: 'MASE' },
                hovertemplate: '%{y} | %{x}<br>MASE: %{z:.4f}<extra></extra>',
                text: chartData.heatmap_z.map(function(row) {
                    return row.map(function(v) { return v.toFixed(4); });
                }),
                texttemplate: '%{text}',
                textfont: { size: 12 }
            };
            Plotly.newPlot('chart-heatmap', [heatTrace], {
                title: { text: 'MASE by Model and Fold', font: { size: 16 } },
                xaxis: { title: '' },
                yaxis: { automargin: true },
                margin: { l: 120, r: 40, t: 50, b: 40 },
                height: Math.max(250, chartData.heatmap_models.length * 50 + 100)
            }, { responsive: true });
        }
    })();
    </script>
</body>
</html>
